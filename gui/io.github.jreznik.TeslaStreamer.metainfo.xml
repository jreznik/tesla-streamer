<component type="desktop-application">
  <id>io.github.jreznik.TeslaStreamer</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>
  <name>Tesla Streamer</name>
  <summary>High-performance screen streaming for Tesla cars</summary>
  <description>
    <p>
      Tesla Streamer allows you to stream your laptop or SteamDeck screen directly to your Tesla's browser with ultra-low latency. 
      It features native Wayland capture, automatic hotspot management, and real-time quality controls.
    </p>
  </description>
  <launchable type="desktop-id">io.github.jreznik.TeslaStreamer.desktop</launchable>
  <provides>
    <binary>tesla-streamer-gui</binary>
    <binary>tesla-streamer</binary>
  </provides>
</component>
